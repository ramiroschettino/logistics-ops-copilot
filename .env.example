# Copiar este archivo a .env y completar
GROQ_API_KEY=
# Para busqueda hibrida (BM25 + embeddings). Gratis en aistudio.google.com.
# Si falta, el RAG funciona igual solo con BM25.
GEMINI_API_KEY=
# true = demo sin LLM (tools reales + respuestas templadas). false = LLM real via Groq
DEMO_MODE=false
MODEL=llama-3.3-70b-versatile
